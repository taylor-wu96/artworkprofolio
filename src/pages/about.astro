---
import Base from '../layouts/Base.astro';
import { urlFor, safeFetch } from '../lib/sanity.js';
import { ABOUT_QUERY } from '../lib/queries.js';
import { PortableText } from 'astro-portabletext';

const about = await safeFetch(ABOUT_QUERY, {}, null);

// CV 展演＝時間軸（資料本質就是時間）：不再依類別分組，改攤平成單一時間脊、
// 依年份遞減排列；類別降為每筆的微標。見 DESIGN 軸 1（展演對齊資料格式）。
const cvCategoryTitles = {
  solo: '個展 / Solo',
  group: '聯展 / Group',
  award: '獲獎 / Award',
  publication: '出版 / Publication',
  other: '經歷 / Other',
};

// 解析開頭四位數年份用於排序（容忍「2023–2024」「2023 春」等寫法）。
const yearOf = (y) => {
  const m = String(y ?? '').match(/\d{4}/);
  return m ? parseInt(m[0], 10) : -Infinity;
};
const cvTimeline = about?.cv
  ? [...about.cv].sort((a, b) => yearOf(b.year) - yearOf(a.year))
  : [];
---

<Base title="關於作者 — 光・門檻・衰敗" activeSection="about">
  <div class="container">
    <header class="section-head grid-12">
      <span class="label section-head__label">介紹 / About</span>
      <h1 class="display section-head__title">關於作者</h1>
    </header>

    {about ? (
      <div class="about-grid grid-12">
        <div class="about-aside" data-reveal>
          {about.photo && (
            <img
              class="about-photo zoomable"
              src={urlFor(about.photo).width(1000).url()}
              data-full={urlFor(about.photo).width(2000).url()}
              alt={about.photo.alt || about.name}
            />
          )}
          <div class="about-contact">
            <h3 class="about-section-title label">聯絡與社群 / Contact</h3>
            <ul class="contact-list">
              {about.contact?.map((c) => (
                <li>
                  <span class="contact-label">{c.label}</span>
                  <a href={c.url} class="contact-link" target="_blank" rel="noopener noreferrer">
                    {c.url.startsWith('mailto:') ? c.url.replace('mailto:', '') : c.url.replace('https://', '')}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="about-content" data-reveal>
          <h2 class="about-name">{about.name}</h2>
          {about.bio && (
            <div class="prose about-bio">
              <PortableText value={about.bio} />
            </div>
          )}

          {cvTimeline.length > 0 && (
            <div class="about-cv">
              <h3 class="about-section-title label" style="margin-bottom: 2rem;">個人經歷 / Curriculum Vitae</h3>
              <ol class="cv-timeline">
                {cvTimeline.map((entry, i) => {
                  // 年份只在「與上一筆不同」時顯示一次——時間脊的錨點。
                  const prev = cvTimeline[i - 1];
                  const showYear = !prev || yearOf(prev.year) !== yearOf(entry.year);
                  return (
                    <li class={`cv-event${i === 0 ? ' cv-event--latest' : ''}`}>
                      <span class="cv-event__year">{showYear ? entry.year : ''}</span>
                      <span class="cv-event__node" aria-hidden="true"></span>
                      <div class="cv-event__body">
                        <span class="cv-event__cat label">
                          {cvCategoryTitles[entry.category || 'other']}
                        </span>
                        <span class="cv-event__title">{entry.title}</span>
                      </div>
                    </li>
                  );
                })}
              </ol>
            </div>
          )}
        </div>
      </div>
    ) : (
      <div class="empty">
        <p>作者資料尚未建立。</p>
        <p>請至 Sanity Studio 新增一個「關於作者 (about)」文件，填寫姓名、照片、個人簡介與 CV，此頁面便會自動呈現。</p>
      </div>
    )}
  </div>
</Base>

<style>
  .about-grid {
    padding-block: clamp(2.5rem, 6vh, 5rem);
    row-gap: 3rem;
  }
  .about-aside {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .about-photo {
    width: 100%;
    max-width: 500px;
    border: 1px solid var(--ink-15);
    background-color: var(--ink-15);
  }
  .about-content {
    grid-column: 1 / -1;
  }
  .about-name {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: var(--fw-semibold); /* 亮房閱讀：報導式半粗 */
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }
  .about-bio {
    font-size: 1.1rem;
    line-height: 1.85;
    margin-bottom: clamp(3rem, 7vh, 5rem);
    color: var(--ink-70);
  }
  
  .about-section-title {
    display: block;
    border-bottom: 1px solid var(--ink-15);
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
    width: 100%;
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .contact-list li {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .contact-label {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: var(--ink-45);
    text-transform: uppercase;
  }
  .contact-link {
    font-size: 0.9rem;
    word-break: break-all;
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-fast) var(--ease);
    align-self: start;
  }
  /* 綠已退出介面 hover（DESIGN §8）：聯絡連結用墨色細線。 */
  .contact-link:hover {
    border-color: currentColor;
  }

  /* ---- CV 時間軸：單一時間脊（年份錨點＋節點＋類別微標）---------------
     資料本質就是時間，故攤平成一條垂直軸；最新一筆帶綠活節點＝still active
     （DESIGN §8 合法綠：生命跡象／最新）。 */
  .cv-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cv-event {
    position: relative;
    display: grid;
    grid-template-columns: 4rem 1fr;
    column-gap: 1.4rem;
    /* 時間脊：節點所在的左欄與內容欄之間一道髮絲縱線。 */
    padding-left: 0;
    padding-bottom: 1.8rem;
  }
  .cv-event:last-child {
    padding-bottom: 0;
  }
  .cv-event__year {
    grid-column: 1;
    font-variant-numeric: tabular-nums;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--ink-45);
    padding-top: 0.1rem;
  }
  /* 節點＋縱脊：節點落在年份欄與內容欄的接縫上。 */
  .cv-event__node {
    position: absolute;
    left: calc(4rem + 0.7rem - 2.5px);
    top: 0.45rem;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--ink-45);
  }
  .cv-event::before {
    content: '';
    position: absolute;
    left: calc(4rem + 0.7rem - 0.5px);
    top: 0.45rem;
    bottom: -0.45rem;
    width: 1px;
    background: var(--ink-15);
  }
  .cv-event:last-child::before {
    display: none;
  }
  /* 最新一筆＝還活著：綠節點＋極慢呼吸（呼應 3D 那一粒綠光、wip 標記）。 */
  .cv-event--latest .cv-event__node {
    background: var(--life);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--life) 22%, transparent);
    animation: cv-node-breathe 3.6s var(--ease) infinite;
  }
  @keyframes cv-node-breathe {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.55; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cv-event--latest .cv-event__node { animation: none; }
  }
  .cv-event__body {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-left: 0.6rem;
  }
  .cv-event__cat {
    color: var(--ink-45);
  }
  .cv-event__title {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--ink-70);
  }

  @media (min-width: 720px) {
    .about-aside {
      grid-column: 1 / 5;
      position: sticky;
      top: 6rem;
      align-self: start;
    }
    .about-content {
      grid-column: 5 / -1;
      padding-left: clamp(1rem, 3vw, 3rem);
    }
  }
</style>
