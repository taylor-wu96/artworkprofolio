---
import Base from '../layouts/Base.astro';
import Hero3D from '../components/Hero3D.jsx';
import { urlFor, safeFetch } from '../lib/sanity.js';
import { ARTWORKS_LIST } from '../lib/queries.js';
import { archiveSignature } from '../lib/signature.js';

const posts = await safeFetch(ARTWORKS_LIST);

const year = (d) => (d ? new Date(d).getFullYear() : null);
const fmtDate = (d) =>
  d ? new Date(d).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' }) : '';

// 依年份分組，呈現時間性的檔案瀏覽。
let lastYear = null;
const total = posts.length;
// 「最新」標記跟著真正最新的日期走（列表已先依精選置頂，i===0 未必最新）。
const newestSlug = [...posts].sort(
  (a, b) => new Date(b.publishedAt ?? 0) - new Date(a.publishedAt ?? 0),
)[0]?.slug;
---

<Base activeSection="works" room="dark">
  <section class="hero">
    <Hero3D client:only="react" />
    <span class="hero__index">攝影檔案 / Archive</span>
    <div class="hero__caption">
      <h1 class="hero__title">光・門檻・衰敗</h1>
      <p class="hero__sub">
        光如何落下、邊界如何被跨越、衰敗與生機如何在同一格底片裡共存。
      </p>
    </div>
  </section>

  <div class="container">
    <header class="section-head grid-12">
      <span class="label section-head__label">索引 / Works</span>
      <h2 class="display section-head__title">作品檔案</h2>
    </header>

    {total > 0 ? (
      <ol class="archive">
        {posts.map((p, i) => {
          const y = year(p.publishedAt);
          const showYear = y !== lastYear;
          lastYear = y;
          const num = String(total - i).padStart(2, '0');
          const sig = archiveSignature(p.slug, p.capture);
          return (
            <>
              {showYear && y && (
                <li class="grid-12" aria-hidden="true">
                  <p class="year-marker">{y}</p>
                </li>
              )}
              <li class="entry grid-12" data-reveal>
                <div class="entry__meta">
                  <span class="entry__num">作品 {num} / {String(total).padStart(2, '0')}</span>
                  {p.status === 'wip' && <span class="entry__wip">進行中 / WIP</span>}
                  {p.slug === newestSlug && <span class="entry__latest">最新 / Latest</span>}
                  {p.themes?.length > 0 && (
                    <span class="entry__themes">
                      {p.themes.map((t) => <span>{t.title}</span>)}
                    </span>
                  )}
                  <span class="entry__num">{fmtDate(p.publishedAt)}</span>
                  <span class="data-strip">
                    <span>{sig.coord}</span>
                    <span class="data-strip__sig">{sig.code}</span>
                    <span>CH.{sig.channel}</span>
                  </span>
                </div>
                <a class="entry__plate" href={`/post/${p.slug}`}>
                  {p.cover ? (
                    <img
                      class="entry__img"
                      src={urlFor(p.cover).width(1600).url()}
                      alt={p.title}
                      loading={i < 2 ? 'eager' : 'lazy'}
                    />
                  ) : (
                    <div class="entry__placeholder">無影像 / NO IMAGE</div>
                  )}
                  <h3 class="entry__title">{p.title}</h3>
                </a>
              </li>
            </>
          );
        })}
      </ol>
    ) : (
      <p class="empty">
        檔案尚未建立。到 Sanity Studio 新增第一件作品，這份索引就會開始記錄。
      </p>
    )}
  </div>
</Base>
