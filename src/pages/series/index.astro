---
import Base from '../../layouts/Base.astro';
import Plate from '../../components/Plate.astro';
import RoomNav from '../../components/RoomNav.astro';
import { safeFetch } from '../../lib/sanity.js';
import { SERIES_LIST } from '../../lib/queries.js';
import { ogImageUrl } from '../../lib/og.js';

const series = await safeFetch(SERIES_LIST);
const total = series.length;
---

<Base
  title="系列 — 光・門檻・衰敗"
  activeSection="series"
  room="dark"
  image={ogImageUrl(series.find((s) => s.cover)?.cover)}
  imageAlt="組曲 / Series"
>
  <div class="container">
    <header class="section-head grid-12">
      <span class="label section-head__label">組曲 / Series</span>
      <h1 class="display section-head__title">系列</h1>
      <p class="section-head__lede">作者編定順序的作品序列。</p>
      <RoomNav current="series" />
    </header>

    {total > 0 ? (
      /* C3 三道門差異（ROADMAP-v3）：系列＝作者手排的「一條連續動線」，故形態是
         一條裝訂線把各站串起（節點＋細線），與「作品」的各自獨立敬awe、與「影像」的
         印樣密排刻意分化——三扇門後是三種不同的看法，不只是三份平行目錄。 */
      <ol class="series-thread">
        {series.map((s, i) => (
          <li class="series-link" data-reveal>
            <a class="series-link__a" href={`/series/${s.slug}`}>
              <span class="series-link__index">
                <span class="series-link__n">{String(i + 1).padStart(2, '0')}</span>
                <span class="series-link__count">{s.count ?? 0} 件序列</span>
              </span>
              <span class="series-link__body">
                <span class="series-link__title">{s.title}</span>
                {s.description && (
                  <span class="series-link__desc">{s.description}</span>
                )}
              </span>
              {s.cover ? (
                <Plate
                  image={s.cover}
                  class="series-link__cover"
                  width={640}
                  sizes="(min-width: 720px) 15rem, 40vw"
                  alt={s.title}
                  loading={i < 3 ? 'eager' : 'lazy'}
                />
              ) : (
                <span class="series-link__cover series-link__cover--empty">無封面 / NO COVER</span>
              )}
            </a>
          </li>
        ))}
      </ol>
    ) : (
      <p class="empty">
        還沒有任何序列被排定。<br />
        當作品被排成一條動線，這裡就會出現第一捲——在那之前，這個房間安靜地空著。
      </p>
    )}
  </div>
</Base>
