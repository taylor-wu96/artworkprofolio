---
import Base from '../../layouts/Base.astro';
import { safeFetch } from '../../lib/sanity.js';
import { ESSAYS_LIST } from '../../lib/queries.js';

const essays = await safeFetch(ESSAYS_LIST);
const total = essays.length;

const fmtDate = (d) =>
  d ? new Date(d).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
---

<Base title="散文創作 — 光・門檻・衰敗" activeSection="writings">
  <div class="container">
    <header class="section-head grid-12">
      <span class="label section-head__label">創作 / Writings</span>
      <h1 class="display section-head__title">散文與隨筆</h1>
    </header>

    {total > 0 ? (
      <ol class="essay-list">
        {essays.map((p, i) => {
          const num = String(total - i).padStart(2, '0');
          return (
            <li class="essay-entry grid-12" data-reveal>
              <div class="essay-entry__meta">
                <span class="essay-entry__num">篇章 {num}</span>
                <span class="essay-entry__num">{fmtDate(p.publishedAt)}</span>
                {p.themes?.length > 0 && (
                  <div class="essay-entry__themes">
                    {p.themes.map((t) => <span>{t.title}</span>)}
                  </div>
                )}
              </div>
              <a class="essay-entry__content" href={`/post/${p.slug}`}>
                <h2 class="essay-entry__title">{p.title}</h2>
                <span class="essay-entry__link">閱讀全文 →</span>
              </a>
            </li>
          );
        })}
      </ol>
    ) : (
      <p class="empty">
        散文隨筆尚未建立。到 Sanity Studio 新增分類為「散文創作」的作品，這份索引就會開始記錄。
      </p>
    )}
  </div>
</Base>

<style>
  /* 散文專屬排版列表 */
  .essay-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .essay-entry {
    padding-block: clamp(2rem, 5vh, 4rem);
    border-bottom: 1px solid var(--ink-15);
  }
  .essay-entry__meta {
    grid-column: 1 / -1;
    display: flex;
    gap: 1.2rem;
    align-items: baseline;
    margin-bottom: 0.8rem;
  }
  .essay-entry__num {
    font-variant-numeric: tabular-nums;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: var(--ink-45);
    text-transform: uppercase;
  }
  .essay-entry__themes {
    display: flex;
    gap: 0.8rem;
    font-size: 0.72rem;
    color: var(--ink-45);
    text-transform: uppercase;
  }
  .essay-entry__content {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .essay-entry__title {
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 500;
    letter-spacing: -0.010em;
    transition: color 0.6s ease;
  }
  .essay-entry__link {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--ink-45);
    transition: color 0.6s ease;
  }
  .essay-entry__content:hover .essay-entry__title {
    color: var(--ink-45);
  }
  .essay-entry__content:hover .essay-entry__link {
    color: var(--ink);
  }

  @media (min-width: 720px) {
    .essay-entry__meta {
      grid-column: 1 / 4;
      flex-direction: column;
      gap: 0.6rem;
      margin-bottom: 0;
      position: sticky;
      top: 5rem;
      align-self: start;
    }
    .essay-entry__content {
      grid-column: 4 / 11;
    }
  }
</style>
