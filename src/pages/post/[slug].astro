---
import Base from '../../layouts/Base.astro';
import { urlFor, safeFetch } from '../../lib/sanity.js';
import { POST_SLUGS, POST_BY_SLUG } from '../../lib/queries.js';
import { PortableText } from 'astro-portabletext';
import PortableImage from '../../components/PortableImage.astro';

export async function getStaticPaths() {
  const slugs = await safeFetch(POST_SLUGS);
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = await safeFetch(POST_BY_SLUG, { slug }, null);

if (!post) {
  return Astro.redirect('/404');
}

const fmtDate = (d) =>
  d ? new Date(d).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
---

<Base title={`${post.title} — 光・門檻・衰敗`} image={post.cover ? urlFor(post.cover).width(1200).url() : undefined}>
  <article class="article container">
    {post.cover && (
      <img
        class="cover zoomable"
        src={urlFor(post.cover).width(1600).height(900).fit('crop').url()}
        data-full={urlFor(post.cover).width(2000).url()}
        alt={post.title}
      />
    )}
    <h1>{post.title}</h1>
    <p class="meta">
      {fmtDate(post.publishedAt)}
      {post.themes?.length > 0 && (
        <>
          {' · '}
          {post.themes.map((t, i) => (
            <>{i > 0 ? '、' : ''}<a href={`/themes/${t.slug}`}>{t.title}</a></>
          ))}
        </>
      )}
    </p>

    {post.body && (
      <div class="prose">
        <PortableText value={post.body} components={{ type: { image: PortableImage } }} />
      </div>
    )}

    {post.gallery?.length > 0 && (
      <div class="gallery">
        {post.gallery.map((img) => (
          <figure>
            <img
              class="zoomable"
              src={urlFor(img).width(800).url()}
              data-full={urlFor(img).width(2000).url()}
              alt={img.caption ?? ''}
              loading="lazy"
            />
            {img.caption && <figcaption>{img.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}
  </article>
</Base>
