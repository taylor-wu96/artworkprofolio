---
import Base from '../../layouts/Base.astro';
import { urlFor, safeFetch } from '../../lib/sanity.js';
import { POST_SLUGS, POST_BY_SLUG } from '../../lib/queries.js';
import { PortableText } from 'astro-portabletext';
import PortableImage from '../../components/PortableImage.astro';
import Sidenote from '../../components/Sidenote.astro';
import Plate from '../../components/Plate.astro';
import { archiveSignature, readExif } from '../../lib/signature.js';
import { signatureGlyph } from '../../lib/glyph.js';
import { ogImageUrl } from '../../lib/og.js';

export async function getStaticPaths() {
  const slugs = await safeFetch(POST_SLUGS);
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = await safeFetch(POST_BY_SLUG, { slug }, null);

if (!post) {
  return Astro.redirect('/404');
}

const fmtDate = (d) =>
  d ? new Date(d).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' }) : '';

// 依分類決定 activeSection 與標籤名稱
const category = post.category || 'artwork';
const activeSection = category === 'gallery' ? 'gallery' : (category === 'essay' ? 'writings' : 'works');
const labelName = category === 'gallery' ? '影像 / Gallery' : (category === 'essay' ? '創作 / Essay' : '作品 / Work');
// 房間：散文＝亮房（閱讀），作品/影像＝暗房（圖錄）。見 DESIGN §1。
const room = category === 'essay' ? 'light' : 'dark';
const sig = archiveSignature(slug, post.capture, post.cover?.asset?.metadata);

// 所屬系列 ＋ 在序列中的位置（第 N / M）。
const seriesInfo = (() => {
  if (!post.series?.slug) return null;
  const order = (post.series.order ?? []).map((o) => o.slug);
  const idx = order.indexOf(post.slug ?? slug);
  return {
    title: post.series.title,
    slug: post.series.slug,
    pos: idx >= 0 ? idx + 1 : null,
    total: order.length,
  };
})();

// 真實拍攝資料（半真化）：有填才顯示，與生成簽名並存。
const cap = post.capture ?? {};
const captureMeta = [cap.location, cap.year, cap.gear, cap.film].filter(Boolean);
// 機器讀檔：封面真 EXIF 五參數（手填器材／底片覆寫）。空則整條不顯。
const exif = readExif(post.cover?.asset?.metadata, cap);

// 動線量詞與關聯資料
const unit = category === 'essay' ? '篇' : category === 'gallery' ? '組' : '件';
const navLabel = category === 'essay' ? '繼續閱讀 / More' : '檔案動線 / Archive';
const kindLabel = (c) => (c === 'essay' ? '散文' : c === 'gallery' ? '影像集' : '作品');
// 固定比例縮圖（4:3，Sanity 裁切——保證一致比例、壓低 payload）。
const thumb = (img) => urlFor(img).width(640).height(480).fit('crop').url();

// 閱讀時間估算（中文 ~350 字/分），僅用於散文頭部。
const readingMinutes = (() => {
  if (!Array.isArray(post.body)) return null;
  let chars = 0;
  for (const blk of post.body) {
    if (blk?._type === 'block' && Array.isArray(blk.children)) {
      for (const c of blk.children) chars += c?.text?.length || 0;
    }
  }
  return chars > 0 ? Math.max(1, Math.round(chars / 350)) : null;
})();

// 分享摘要：取內文首段（≤140 字），缺則由主題拼一句；最後回退站台預設。
const excerpt = (() => {
  if (Array.isArray(post.body)) {
    for (const blk of post.body) {
      if (blk?._type === 'block' && Array.isArray(blk.children)) {
        const t = blk.children.map((c) => c?.text || '').join('').trim();
        if (t) return t.length > 140 ? `${t.slice(0, 140)}…` : t;
      }
    }
  }
  if (post.themes?.length) return `${labelName} · ${post.themes.map((t) => t.title).join('、')}`;
  return undefined;
})();
const ogImg = ogImageUrl(post.cover);

// 放映模式的策展論述：作品陳述首段（完整，不截斷）。放映時可呼出。無則不掛。
const statement = (() => {
  if (!Array.isArray(post.body)) return null;
  for (const blk of post.body) {
    if (blk?._type === 'block' && Array.isArray(blk.children)) {
      const t = blk.children.map((c) => c?.text || '').join('').trim();
      if (t) return t;
    }
  }
  return null;
})();
---

<Base
  title={`${post.title} — 潮濕的質地`}
  description={excerpt}
  image={ogImg}
  imageAlt={post.cover?.alt ?? post.title}
  activeSection={activeSection}
  room={room}
>
  <article class={`detail-view container ${category}-view`}>
    {/* 放映模式讀此隱藏節點作為策展論述（Press Release）。不顯於頁面本身。 */}
    {statement && <p class="pjx-statement" hidden set:text={statement} />}

    {category === 'essay' ? (
      /* --- 散文創作排版 --- */
      <div class="essay-layout" data-reveal data-read-progress>
        <header class="essay-header">
          <span class="label essay-label">{labelName}</span>
          <h2 class="essay-title">{post.title}</h2>
          <div class="essay-meta">
            <span>{fmtDate(post.publishedAt)}</span>
            {readingMinutes && <span>約 {readingMinutes} 分鐘</span>}
            {post.themes?.length > 0 &&
              post.themes.map((t) => <a href={`/themes/${t.slug}`} class="essay-theme-link">{t.title}</a>)}
            {seriesInfo && (
              <a href={`/series/${seriesInfo.slug}`} class="essay-theme-link">
                系列 · {seriesInfo.title}{seriesInfo.pos ? ` ${seriesInfo.pos}/${seriesInfo.total}` : ''}
              </a>
            )}
          </div>
        </header>

        {post.cover && (
          <Plate
            image={post.cover}
            class="essay-cover"
            width={1600}
            full={2400}
            zoomable
            sizes="(min-width: 720px) 40rem, 100vw"
            alt={post.title}
            transitionName={`cover-${slug}`}
          />
        )}

        {post.body && (
          <div class="prose prose--essay">
            <PortableText value={post.body} components={{ type: { image: PortableImage }, mark: { sidenote: Sidenote } }} />
          </div>
        )}
      </div>
    ) : category === 'gallery' ? (
      /* --- 影像集排版 --- */
      <div class="gallery-layout">
        {/* 封面滿版領銜到場，標題與 meta 疊在影像下緣（produx /studio 模型・creator 回饋
            2026-06-30）。影像第一眼撞進來，文字是其上的圖說，不再孤浮於上半屏死黑。 */}
        {post.cover ? (
          <figure class="work__hero">
            <Plate
              image={post.cover}
              class="work__hero-img"
              width={2400}
              full={2800}
              zoomable
              reveal
              sizes="100vw"
              alt={post.title}
              transitionName={`cover-${slug}`}
            />
            <figcaption class="work__hero-cap">
              <span class="label work__hero-eyebrow">{labelName}</span>
              <h1 class="work__hero-title">{post.title}</h1>
              <div class="work__meta work__hero-meta">
                <span>{fmtDate(post.publishedAt)}</span>
                {post.themes?.length > 0 &&
                  post.themes.map((t) => <a href={`/themes/${t.slug}`}>{t.title}</a>)}
                {seriesInfo && (
                  <a href={`/series/${seriesInfo.slug}`}>
                    系列 · {seriesInfo.title}{seriesInfo.pos ? ` ${seriesInfo.pos}/${seriesInfo.total}` : ''}
                  </a>
                )}
              </div>
            </figcaption>
          </figure>
        ) : (
          /* 無封面退回純文字標頭（不丟資訊）。 */
          <header class="work__header grid-12">
            <span class="label" style="grid-column: 1 / -1">{labelName}</span>
            <h1 class="work__title">{post.title}</h1>
            <div class="work__meta">
              <span>{fmtDate(post.publishedAt)}</span>
              {post.themes?.length > 0 &&
                post.themes.map((t) => <a href={`/themes/${t.slug}`}>{t.title}</a>)}
              {seriesInfo && (
                <a href={`/series/${seriesInfo.slug}`}>
                  系列 · {seriesInfo.title}{seriesInfo.pos ? ` ${seriesInfo.pos}/${seriesInfo.total}` : ''}
                </a>
              )}
            </div>
          </header>
        )}

        {/* 機器讀檔 chrome 降到影像之下：資料條／簽名章／拍攝參數／真 EXIF，安靜成檔案註腳。 */}
        {(sig.real || captureMeta.length > 0 || exif.length > 0) && (
          <div class="work__filemeta grid-12">
            {sig.real && (
              <p class="data-strip work__data">
                {sig.coord && <span>{sig.coord}</span>}
                <span class="data-strip__sig">{sig.code}</span>
                <span>CH.{sig.channel}</span>
              </p>
            )}
            <div class="work__glyph" set:html={signatureGlyph(slug, { size: 44 })} />
            {captureMeta.length > 0 && (
              <p class="work__capture">
                {captureMeta.map((m) => <span>{m}</span>)}
              </p>
            )}
            {exif.length > 0 && (
              <details class="work__exif">
                <summary>
                  <span class="work__exif__hint">讀取檔案 / Read file</span>
                </summary>
                <p class="work__exif__row">
                  {exif.map((p) => <span>{p}</span>)}
                </p>
              </details>
            )}
          </div>
        )}

        {post.body && (
          <div class="prose" style="margin-bottom: clamp(3rem, 8vh, 6rem);">
            <PortableText value={post.body} components={{ type: { image: PortableImage }, mark: { sidenote: Sidenote } }} />
          </div>
        )}

        {post.gallery?.length > 0 && (
          <div class="plates plates--gallery">
            {post.gallery.map((img, i) => (
              /* 兩欄：左＝大編號＋圖說「文」（≥md sticky 隨影像並行），右＝影像（捲動顯影動畫）。
                 figcaption 仍留在 figure 內——放映 lightbox 由此讀圖說，不破。 */
              <figure class="gallery-item">
                <div class="gallery-item__aside">
                  <div class="gallery-item__num">
                    <span class="gallery-item__n">{String(i + 1).padStart(2, '0')}</span>
                    <span class="gallery-item__total">／{String(post.gallery.length).padStart(2, '0')}</span>
                  </div>
                  {img.caption && <figcaption class="gallery-caption">{img.caption}</figcaption>}
                </div>
                <div class="gallery-item__media">
                  <Plate
                    image={img}
                    width={2000}
                    full={2600}
                    zoomable
                    sizes="(min-width: 720px) 60vh, 100vw"
                    alt={img.caption ?? ''}
                    loading="lazy"
                  />
                </div>
              </figure>
            ))}
          </div>
        )}
      </div>
    ) : (
      /* --- 預設作品排版 --- */
      <div class="artwork-layout">
        <header class="work__header grid-12">
          <span class="label" style="grid-column: 1 / -1">{labelName}</span>
          <h1 class="display work__title">{post.title}</h1>
          <div class="work__meta">
            <span>{fmtDate(post.publishedAt)}</span>
            {post.themes?.length > 0 &&
              post.themes.map((t) => <a href={`/themes/${t.slug}`}>{t.title}</a>)}
            {seriesInfo && (
              <a href={`/series/${seriesInfo.slug}`}>
                系列 · {seriesInfo.title}{seriesInfo.pos ? ` ${seriesInfo.pos}/${seriesInfo.total}` : ''}
              </a>
            )}
          </div>
          {/* S1 誠實化：有真座標/年份才顯示資料條，否則沉默（不捏造觀看痕跡）。 */}
          {sig.real && (
            <p class="data-strip work__data">
              {sig.coord && <span>{sig.coord}</span>}
              <span class="data-strip__sig">{sig.code}</span>
              <span>CH.{sig.channel}</span>
            </p>
          )}
          <div class="work__glyph" set:html={signatureGlyph(slug, { size: 44 })} />
          {captureMeta.length > 0 && (
            <p class="work__capture">
              {captureMeta.map((m) => <span>{m}</span>)}
            </p>
          )}
          {exif.length > 0 && (
            /* 機器讀檔：預設收起（克制），點擊／鍵盤展開真 EXIF。配角，影像為主。 */
            <details class="work__exif">
              <summary>
                <span class="work__exif__hint">讀取檔案 / Read file</span>
              </summary>
              <p class="work__exif__row">
                {exif.map((p) => <span>{p}</span>)}
              </p>
            </details>
          )}
        </header>

        {post.cover && (
          <Plate
            image={post.cover}
            class="work__cover"
            width={2000}
            full={2600}
            zoomable
            reveal
            sizes="100vw"
            alt={post.title}
            transitionName={`cover-${slug}`}
          />
        )}

        {post.body && (
          <div class="prose artwork-statement">
            <PortableText value={post.body} components={{ type: { image: PortableImage }, mark: { sidenote: Sidenote } }} />
          </div>
        )}

        {post.gallery?.length > 0 && (
          /* 附圖＝次要「其他視圖」，刻意不編號（編號是影像集序列的語言），
             與單一主影像分化。見 DESIGN 軸 1。 */
          <section class="artwork-plates">
            <span class="label artwork-plates__label">其他視圖 / Other Views</span>
            <div class="plates">
              {post.gallery.map((img) => (
                <figure data-reveal>
                  <Plate
                    image={img}
                    width={2000}
                    full={2600}
                    zoomable
                    sizes="100vw"
                    alt={img.caption ?? ''}
                    loading="lazy"
                  />
                  {img.caption && <figcaption>{img.caption}</figcaption>}
                </figure>
              ))}
            </div>
          </section>
        )}
      </div>
    )}

    {(post.related?.length > 0 || post.prev || post.next) && (
      <nav class={`post-nav ${category === 'essay' ? 'post-nav--essay' : ''}`} aria-label="檔案動線">
        <span class="label post-nav__label">{navLabel}</span>

        {post.related?.length > 0 && (
          <ul class="post-nav__related">
            {post.related.map((r) => (
              <li class="post-nav__item">
                <a href={`/post/${r.slug}`}>
                  <span class="post-nav__thumb">
                    {r.cover && <img src={thumb(r.cover)} alt={r.title} loading="lazy" />}
                  </span>
                  <span class="post-nav__rinfo">
                    <span class="post-nav__rtitle">{r.title}</span>
                    <span class="post-nav__rkind">
                      {kindLabel(r.category)}{r.themes?.[0] ? ` · ${r.themes[0].title}` : ''}
                    </span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )}

        {(post.prev || post.next) && (
          <div class="post-nav__adjacent">
            {post.prev ? (
              <a class="post-nav__step" href={`/post/${post.prev.slug}`}>
                <span class="post-nav__dir"><span class="post-nav__arrow">←</span> 上一{unit}</span>
                <span class="post-nav__name">{post.prev.title}</span>
              </a>
            ) : (
              <span class="post-nav__step post-nav__step--empty" aria-hidden="true"></span>
            )}
            {post.next && (
              <a class="post-nav__step post-nav__step--next" href={`/post/${post.next.slug}`}>
                <span class="post-nav__dir">下一{unit} <span class="post-nav__arrow">→</span></span>
                <span class="post-nav__name">{post.next.title}</span>
              </a>
            )}
          </div>
        )}
      </nav>
    )}
  </article>
</Base>

<style>
  /* ---- 影像集內頁：封面滿版 + 標題疊圖（produx /studio 模型・creator 回饋 2026-06-30）----
     封面 100vw 滿版領銜（自然比例、不裁切，DESIGN §五），標題與 meta 疊在影像下緣的
     漸層遮罩上；機器 chrome 全降到影像之下。治「標題孤浮於上半屏死黑」的根因。 */
  .work__hero {
    position: relative;
    width: 100vw;
    overflow:hidden;  
    margin-left: calc(50% - 50vw);
    margin-bottom: clamp(1.8rem, 5vh, 3.4rem);
  }
  .work__hero :global(.work__hero-img) {
    display: block;
    width: 100%;
  }
  .work__hero-cap {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: clamp(3.5rem, 18vh, 11rem) var(--margin) clamp(1.6rem, 5vh, 3rem);
    /* 顯影式遮罩：不是貼一條黑帶，而是影像底部平滑溶進暗房色（#0c0c0b＝放映層基色）。
       多段近-ease 曲線讓過渡看不見接縫；subtractive 減光、非 glow（合規）。 */
    background: linear-gradient(
      to top,
      rgba(12, 12, 11, 0.9) 0%,
      rgba(12, 12, 11, 0.74) 20%,
      rgba(12, 12, 11, 0.46) 48%,
      rgba(12, 12, 11, 0.16) 76%,
      rgba(12, 12, 11, 0) 100%
    );
  }
  .work__hero-eyebrow {
    display: block;
    margin-bottom: clamp(0.8rem, 1.6vh, 1.1rem);
    color: color-mix(in oklab, var(--paper) 56%, transparent);
  }
  .work__hero-title {
    font-family: var(--font-title);
    /* 壓圖需可讀，故比 index 大標略重（400）；黑體收字距、行高略緊。 */
    font-size: clamp(1.55rem, 3.1vw, 2.4rem);
    font-weight: var(--fw-regular);
    line-height: 1.18;
    letter-spacing: 0.02em;
    color: var(--paper);
    max-width: 20ch;
    text-wrap: balance;
  }
  .work__hero-meta {
    margin-top: clamp(0.85rem, 2.2vh, 1.25rem);
    color: color-mix(in oklab, var(--paper) 68%, transparent);
  }
  .work__hero-meta a:hover {
    color: var(--paper);
  }

  /* 機器 chrome 降到影像之下，在 12 欄內安靜成檔案註腳。 */
  .work__filemeta {
    margin-bottom: clamp(2.5rem, 7vh, 5rem);
    align-items: start;
  }

  /* 作品頭部資料條（Ikeda 式檔案座標）*/
  .work__data {
    grid-column: 1 / -1;
    margin-top: 0.9rem;
  }

  /* 散文專屬精緻排版 */
  .essay-layout {
    max-width: var(--measure);
    margin: 0 auto;
    padding-block: clamp(3rem, 8vh, 6rem);
  }
  /* 報導者式編輯標頭：靠左、與內文同軸，下緣髮絲分隔。 */
  .essay-header {
    text-align: left;
    margin-bottom: clamp(2.5rem, 7vh, 4.5rem);
    padding-bottom: clamp(1.5rem, 4vh, 2.4rem);
    border-bottom: 1px solid var(--line);
  }
  .essay-label {
    display: block;
    margin-bottom: 1rem;
  }
  .essay-title {
    font-size: clamp(1.6rem, 3.2vw, 2.2rem); /* v2.2 收斂 */
    font-weight: var(--fw-semibold); /* 亮房閱讀：報導式半粗標題 */
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin-bottom: 1.2rem;
    color: var(--text);
  }
  .essay-meta {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 1.2rem;
  }
  .essay-theme-link {
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-fast) var(--ease);
  }
  /* 綠已退出內文/介面 hover（DESIGN §8）：主題連結用墨色細線。 */
  .essay-theme-link:hover {
    border-color: currentColor;
  }
  /* essay-cover 套在 Plate 外層 .plate（子元件，不帶本檔 scope）→ 用 :global。 */
  :global(.essay-cover) {
    width: 100%;
    margin-bottom: clamp(3rem, 8vh, 5rem);
    border: 1px solid var(--line);
  }

  .prose--essay {
    font-family: var(--font-read);
    font-size: var(--read-size);
    line-height: 1.85;
    color: var(--text-body); /* 亮房長文實墨對比（與 .prose 同步，承導言重量）*/
    letter-spacing: 0.01em;
  }
  /* 導言（lead）：開場段落略大、實墨、行高更鬆，承擔開場重量。
     用 :global——段落由 PortableText 子元件輸出，不帶本檔的 scope 屬性。 */
  :global(.prose--essay > p:first-of-type) {
    font-size: 1.28rem;
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 2rem;
  }

  /* 影像集 gallery 版面（.gallery-layout / .plates--gallery / .gallery-item*）已下沉到
     全域 components 層——避開 Astro ClientRouter view-transition 後頁級 scoped 樣式
     短暫失效導致的 grid 塌陷（中文圖說直排）。見 styles/layers/components.css。 */

  /* 真實拍攝資料（半真化）：編輯說明行，中點分隔。 */
  .work__capture {
    grid-column: 1 / -1;
    margin-top: 0.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    font-size: var(--step--2);
    letter-spacing: 0.04em;
    color: var(--text-dim);
  }
  .work__capture span {
    position: relative;
  }
  .work__capture span + span::before {
    content: '·';
    position: absolute;
    left: -0.7rem;
    color: var(--text-dim);
  }

  /* ---- 機器讀檔（真 EXIF 揭示）：等寬、克制、配角 -----------------------
     收起時只見一行 mono 提示；展開（details）顯五參數。原生 disclosure＝
     鍵盤／觸控／滑鼠皆可，無 JS。綠＝可被啟動的訊號（hover／open，§4.1 白名單）。 */
  .work__exif {
    grid-column: 1 / -1;
