---
import Base from '../../layouts/Base.astro';
import { urlFor, safeFetch } from '../../lib/sanity.js';
import { POST_SLUGS, POST_BY_SLUG } from '../../lib/queries.js';
import { PortableText } from 'astro-portabletext';
import PortableImage from '../../components/PortableImage.astro';
import Sidenote from '../../components/Sidenote.astro';
import Plate from '../../components/Plate.astro';
import { archiveSignature } from '../../lib/signature.js';
import { signatureGlyph } from '../../lib/glyph.js';

export async function getStaticPaths() {
  const slugs = await safeFetch(POST_SLUGS);
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = await safeFetch(POST_BY_SLUG, { slug }, null);

if (!post) {
  return Astro.redirect('/404');
}

const fmtDate = (d) =>
  d ? new Date(d).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' }) : '';

// 依分類決定 activeSection 與標籤名稱
const category = post.category || 'artwork';
const activeSection = category === 'gallery' ? 'gallery' : (category === 'essay' ? 'writings' : 'works');
const labelName = category === 'gallery' ? '影像 / Gallery' : (category === 'essay' ? '創作 / Essay' : '作品 / Work');
// 房間：散文＝亮房（閱讀），作品/影像＝暗房（圖錄）。見 DESIGN §1。
const room = category === 'essay' ? 'light' : 'dark';
const sig = archiveSignature(slug, post.capture, post.cover?.asset?.metadata);

// 所屬系列 ＋ 在序列中的位置（第 N / M）。
const seriesInfo = (() => {
  if (!post.series?.slug) return null;
  const order = (post.series.order ?? []).map((o) => o.slug);
  const idx = order.indexOf(post.slug ?? slug);
  return {
    title: post.series.title,
    slug: post.series.slug,
    pos: idx >= 0 ? idx + 1 : null,
    total: order.length,
  };
})();

// 真實拍攝資料（半真化）：有填才顯示，與生成簽名並存。
const cap = post.capture ?? {};
const captureMeta = [cap.location, cap.year, cap.gear, cap.film].filter(Boolean);

// 動線量詞與關聯資料
const unit = category === 'essay' ? '篇' : category === 'gallery' ? '組' : '件';
const navLabel = category === 'essay' ? '繼續閱讀 / More' : '檔案動線 / Archive';
const kindLabel = (c) => (c === 'essay' ? '散文' : c === 'gallery' ? '影像集' : '作品');
// 固定比例縮圖（4:3，Sanity 裁切——保證一致比例、壓低 payload）。
const thumb = (img) => urlFor(img).width(640).height(480).fit('crop').url();

// 閱讀時間估算（中文 ~350 字/分），僅用於散文頭部。
const readingMinutes = (() => {
  if (!Array.isArray(post.body)) return null;
  let chars = 0;
  for (const blk of post.body) {
    if (blk?._type === 'block' && Array.isArray(blk.children)) {
      for (const c of blk.children) chars += c?.text?.length || 0;
    }
  }
  return chars > 0 ? Math.max(1, Math.round(chars / 350)) : null;
})();
---

<Base
  title={`${post.title} — 光・門檻・衰敗`}
  image={post.cover ? urlFor(post.cover).width(1200).url() : undefined}
  activeSection={activeSection}
  room={room}
>
  <article class={`detail-view container ${category}-view`}>
    
    {category === 'essay' ? (
      /* --- 散文創作排版 --- */
      <div class="essay-layout" data-reveal data-read-progress>
        <header class="essay-header">
          <span class="label essay-label">{labelName}</span>
          <h1 class="essay-title">{post.title}</h1>
          <div class="essay-meta">
            <span>{fmtDate(post.publishedAt)}</span>
            {readingMinutes && <span>約 {readingMinutes} 分鐘</span>}
            {post.themes?.length > 0 &&
              post.themes.map((t) => <a href={`/themes/${t.slug}`} class="essay-theme-link">{t.title}</a>)}
            {seriesInfo && (
              <a href={`/series/${seriesInfo.slug}`} class="essay-theme-link">
                系列 · {seriesInfo.title}{seriesInfo.pos ? ` ${seriesInfo.pos}/${seriesInfo.total}` : ''}
              </a>
            )}
          </div>
        </header>

        {post.cover && (
          <Plate
            image={post.cover}
            class="essay-cover"
            width={1600}
            full={2400}
            zoomable
            sizes="(min-width: 720px) 40rem, 100vw"
            alt={post.title}
          />
        )}

        {post.body && (
          <div class="prose prose--essay">
            <PortableText value={post.body} components={{ type: { image: PortableImage }, mark: { sidenote: Sidenote } }} />
          </div>
        )}
      </div>
    ) : category === 'gallery' ? (
      /* --- 影像集排版 --- */
      <div class="gallery-layout">
        <header class="work__header grid-12">
          <span class="label" style="grid-column: 1 / -1">{labelName}</span>
          <h1 class="display work__title">{post.title}</h1>
          <div class="work__meta">
            <span>{fmtDate(post.publishedAt)}</span>
            {post.themes?.length > 0 &&
              post.themes.map((t) => <a href={`/themes/${t.slug}`}>{t.title}</a>)}
            {seriesInfo && (
              <a href={`/series/${seriesInfo.slug}`}>
                系列 · {seriesInfo.title}{seriesInfo.pos ? ` ${seriesInfo.pos}/${seriesInfo.total}` : ''}
              </a>
            )}
          </div>
          <p class="data-strip work__data">
            <span>{sig.coord}</span>
            <span class="data-strip__sig">{sig.code}</span>
            <span>CH.{sig.channel}</span>
          </p>
          <div class="work__glyph" set:html={signatureGlyph(slug, { size: 44 })} />
          {captureMeta.length > 0 && (
            <p class="work__capture">
              {captureMeta.map((m) => <span>{m}</span>)}
            </p>
          )}
        </header>

        {post.cover && (
          <Plate
            image={post.cover}
            class="work__cover"
            width={2000}
            full={2600}
            zoomable
            reveal
            sizes="100vw"
            alt={post.title}
          />
        )}

        {post.body && (
          <div class="prose" style="margin-bottom: clamp(3rem, 8vh, 6rem);">
            <PortableText value={post.body} components={{ type: { image: PortableImage }, mark: { sidenote: Sidenote } }} />
          </div>
        )}

        {post.gallery?.length > 0 && (
          <div class="plates plates--gallery">
            {post.gallery.map((img, i) => (
              <figure class="gallery-item grid-12" data-reveal>
                <div class="gallery-item__num label">影像 {String(i + 1).padStart(2, '0')} / {String(post.gallery.length).padStart(2, '0')}</div>
                <div class="gallery-item__media">
                  <Plate
                    image={img}
                    width={2000}
                    full={2600}
                    zoomable
                    sizes="(min-width: 720px) 66vw, 100vw"
                    alt={img.caption ?? ''}
                    loading="lazy"
                  />
                  {img.caption && <figcaption class="gallery-caption">{img.caption}</figcaption>}
                </div>
              </figure>
            ))}
          </div>
        )}
      </div>
    ) : (
      /* --- 預設作品排版 --- */
      <div class="artwork-layout">
        <header class="work__header grid-12">
          <span class="label" style="grid-column: 1 / -1">{labelName}</span>
          <h1 class="display work__title">{post.title}</h1>
          <div class="work__meta">
            <span>{fmtDate(post.publishedAt)}</span>
            {post.themes?.length > 0 &&
              post.themes.map((t) => <a href={`/themes/${t.slug}`}>{t.title}</a>)}
            {seriesInfo && (
              <a href={`/series/${seriesInfo.slug}`}>
                系列 · {seriesInfo.title}{seriesInfo.pos ? ` ${seriesInfo.pos}/${seriesInfo.total}` : ''}
              </a>
            )}
          </div>
          <p class="data-strip work__data">
            <span>{sig.coord}</span>
            <span class="data-strip__sig">{sig.code}</span>
            <span>CH.{sig.channel}</span>
          </p>
          <div class="work__glyph" set:html={signatureGlyph(slug, { size: 44 })} />
          {captureMeta.length > 0 && (
            <p class="work__capture">
              {captureMeta.map((m) => <span>{m}</span>)}
            </p>
          )}
        </header>

        {post.cover && (
          <Plate
            image={post.cover}
            class="work__cover"
            width={2000}
            full={2600}
            zoomable
            reveal
            sizes="100vw"
            alt={post.title}
          />
        )}

        {post.body && (
          <div class="prose">
            <PortableText value={post.body} components={{ type: { image: PortableImage }, mark: { sidenote: Sidenote } }} />
          </div>
        )}

        {post.gallery?.length > 0 && (
          <div class="plates">
            {post.gallery.map((img) => (
              <figure data-reveal>
                <Plate
                  image={img}
                  width={2000}
                  full={2600}
                  zoomable
                  sizes="100vw"
                  alt={img.caption ?? ''}
                  loading="lazy"
                />
                {img.caption && <figcaption>{img.caption}</figcaption>}
              </figure>
            ))}
          </div>
        )}
      </div>
    )}

    {(post.related?.length > 0 || post.prev || post.next) && (
      <nav class={`post-nav ${category === 'essay' ? 'post-nav--essay' : ''}`} aria-label="檔案動線">
        <span class="label post-nav__label">{navLabel}</span>

        {post.related?.length > 0 && (
          <ul class="post-nav__related">
            {post.related.map((r) => (
              <li class="post-nav__item">
                <a href={`/post/${r.slug}`}>
                  <span class="post-nav__thumb">
                    {r.cover && <img src={thumb(r.cover)} alt={r.title} loading="lazy" />}
                  </span>
                  <span class="post-nav__rinfo">
                    <span class="post-nav__rtitle">{r.title}</span>
                    <span class="post-nav__rkind">
                      {kindLabel(r.category)}{r.themes?.[0] ? ` · ${r.themes[0].title}` : ''}
                    </span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )}

        {(post.prev || post.next) && (
          <div class="post-nav__adjacent">
            {post.prev ? (
              <a class="post-nav__step" href={`/post/${post.prev.slug}`}>
                <span class="post-nav__dir"><span class="post-nav__arrow">←</span> 上一{unit}</span>
                <span class="post-nav__name">{post.prev.title}</span>
              </a>
            ) : (
              <span class="post-nav__step post-nav__step--empty" aria-hidden="true"></span>
            )}
            {post.next && (
              <a class="post-nav__step post-nav__step--next" href={`/post/${post.next.slug}`}>
                <span class="post-nav__dir">下一{unit} <span class="post-nav__arrow">→</span></span>
                <span class="post-nav__name">{post.next.title}</span>
              </a>
            )}
          </div>
        )}
      </nav>
    )}
  </article>
</Base>

<style>
  /* 作品頭部資料條（Ikeda 式檔案座標）*/
  .work__data {
    grid-column: 1 / -1;
    margin-top: 0.9rem;
  }

  /* 散文專屬精緻排版 */
  .essay-layout {
    max-width: var(--measure);
    margin: 0 auto;
    padding-block: clamp(3rem, 8vh, 6rem);
  }
  /* 報導者式編輯標頭：靠左、與內文同軸，下緣髮絲分隔。 */
  .essay-header {
    text-align: left;
    margin-bottom: clamp(2.5rem, 7vh, 4.5rem);
    padding-bottom: clamp(1.5rem, 4vh, 2.4rem);
    border-bottom: 1px solid var(--line);
  }
  .essay-label {
    display: block;
    margin-bottom: 1rem;
  }
  .essay-title {
    font-size: clamp(1.6rem, 3.2vw, 2.2rem); /* v2.2 收斂 */
    font-weight: var(--fw-semibold); /* 亮房閱讀：報導式半粗標題 */
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin-bottom: 1.2rem;
    color: var(--text);
  }
  .essay-meta {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 1.2rem;
  }
  .essay-theme-link {
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-fast) var(--ease);
  }
  /* 綠已退出內文/介面 hover（DESIGN §8）：主題連結用墨色細線。 */
  .essay-theme-link:hover {
    border-color: currentColor;
  }
  /* essay-cover 套在 Plate 外層 .plate（子元件，不帶本檔 scope）→ 用 :global。 */
  :global(.essay-cover) {
    width: 100%;
    margin-bottom: clamp(3rem, 8vh, 5rem);
    border: 1px solid var(--line);
  }

  .prose--essay {
    font-family: var(--font-read);
    font-size: var(--read-size);
    line-height: 1.85;
    color: var(--text-muted);
    letter-spacing: 0.01em;
  }
  /* 導言（lead）：開場段落略大、實墨、行高更鬆，承擔開場重量。
     用 :global——段落由 PortableText 子元件輸出，不帶本檔的 scope 屬性。 */
  :global(.prose--essay > p:first-of-type) {
    font-size: 1.28rem;
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 2rem;
  }

  /* 影像集專屬排版 */
  .plates--gallery {
    margin-top: clamp(2rem, 5vh, 4rem);
    display: flex;
    flex-direction: column;
    gap: clamp(4rem, 12vh, 8rem);
  }
  .gallery-item {
    column-gap: var(--col-gap);
    row-gap: 1rem;
  }
  .gallery-item__num {
    grid-column: 1 / -1;
    color: var(--ink-45);
    font-variant-numeric: tabular-nums;
  }
  .gallery-item__media {
    grid-column: 1 / -1;
  }
  .gallery-caption {
    margin-top: 1rem;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--text-dim);
    line-height: 1.5;
    max-width: var(--measure);
  }

  @media (min-width: 720px) {
    .gallery-item__num {
      grid-column: 1 / 4;
      position: sticky;
      top: 6rem;
      align-self: start;
      padding-top: 0.5rem;
    }
    .gallery-item__media {
      grid-column: 4 / -1;
    }
  }

  /* 真實拍攝資料（半真化）：編輯說明行，中點分隔。 */
  .work__capture {
    grid-column: 1 / -1;
    margin-top: 0.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    font-size: var(--step--2);
    letter-spacing: 0.04em;
    color: var(--text-dim);
  }
  .work__capture span {
    position: relative;
  }
  .work__capture span + span::before {
    content: '·';
    position: absolute;
    left: -0.7rem;
    color: var(--text-dim);
  }

  /* ---- 檔案動線：related + 上下篇（語意 token → 隨房間自動換色）-------- */
  .post-nav {
    margin-top: clamp(4rem, 12vh, 8rem);
    padding-top: clamp(1.6rem, 4vh, 2.4rem);
    border-top: 1px solid var(--line);
  }
  .post-nav--essay {
    max-width: var(--measure);
    margin-inline: auto;
  }
  .post-nav__label {
    display: block;
    margin-bottom: clamp(1.4rem, 3vh, 2rem);
    color: var(--text-dim);
  }

  /* related —— 預設＝閱讀（亮房）的編輯式清單：小固定縮圖＋標題，文字優先。 */
  .post-nav__related {
    list-style: none;
    margin: 0 0 clamp(2.4rem, 6vh, 3.6rem);
    padding: 0;
  }
  .post-nav__item a {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 1.3rem;
    align-items: center;
    padding: 0.9rem 0;
    border-top: 1px solid var(--line);
  }
  .post-nav__related li:last-child a {
    border-bottom: 1px solid var(--line);
  }
  .post-nav__thumb {
    display: block;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: color-mix(in oklab, var(--text) 6%, transparent);
  }
  .post-nav__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .post-nav__rinfo {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }
  .post-nav__rtitle {
    font-size: var(--step-0);
    color: var(--text);
    transition: color var(--dur) var(--ease);
  }
  .post-nav__rkind {
    font-size: var(--step--2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .post-nav__item a:hover .post-nav__rtitle {
    color: var(--accent);
  }
  .post-nav__item a:hover .post-nav__thumb img {
    opacity: 0.82;
    transform: scale(1.03);
  }

  /* 上下篇 —— 兩半骨架，綠色方向訊號（可前進的活路）。 */
  .post-nav__adjacent {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .post-nav__step,
  .post-nav__step--empty {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.3rem 1.4rem 0.4rem 0;
    border-top: 1px solid var(--line);
    transition: border-color var(--dur) var(--ease);
  }
  .post-nav__step--next {
    text-align: right;
    align-items: flex-end;
    padding: 1.3rem 0 0.4rem 1.4rem;
  }
  .post-nav__dir {
    font-size: var(--step--2);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  /* 綠＝可前進的活路（DESIGN §8 互動訊號）：箭頭恆綠、hover 收攏。 */
  .post-nav__arrow {
    display: inline-block;
    color: var(--accent);
    transition: transform var(--dur) var(--ease);
  }
  .post-nav__name {
    font-size: var(--step-1);
    line-height: 1.3;
    color: var(--text-muted);
    transition: color var(--dur) var(--ease);
  }
  .post-nav__step:hover {
    border-color: var(--accent);
  }
  .post-nav__step:hover .post-nav__name {
    color: var(--text);
  }
  .post-nav__step:not(.post-nav__step--next):hover .post-nav__arrow {
    transform: translateX(-0.25rem);
  }
  .post-nav__step--next:hover .post-nav__arrow {
    transform: translateX(0.25rem);
  }

  /* 暗房（圖錄）：related 改縮圖網格——展牆語境，視覺優先。 */
  .post-nav:not(.post-nav--essay) .post-nav__related {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1rem, 2.5vw, 1.6rem);
  }
  .post-nav:not(.post-nav--essay) .post-nav__item a {
    display: block;
    gap: 0;
    padding: 0;
    border: 0;
  }
  .post-nav:not(.post-nav--essay) .post-nav__related li:last-child a {
    border: 0;
  }
  .post-nav:not(.post-nav--essay) .post-nav__thumb {
    aspect-ratio: 4 / 3;
  }
  .post-nav:not(.post-nav--essay) .post-nav__rinfo {
    margin-top: 0.7rem;
  }
  .post-nav:not(.post-nav--essay) .post-nav__rtitle {
    font-size: var(--step--1);
    font-weight: var(--fw-regular);
  }

  @media (min-width: 720px) {
    .post-nav:not(.post-nav--essay) .post-nav__related {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  @media (max-width: 520px) {
    .post-nav__adjacent {
      grid-template-columns: 1fr;
    }
    .post-nav__step--next {
      text-align: left;
      align-items: flex-start;
      padding: 1.3rem 0 0.4rem 0;
    }
    .post-nav__step--empty {
      display: none;
    }
  }
</style>
