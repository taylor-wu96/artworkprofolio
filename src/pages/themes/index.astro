---
import Base from '../../layouts/Base.astro';
import { urlFor, safeFetch } from '../../lib/sanity.js';
import { THEMES_LIST } from '../../lib/queries.js';
import { ogImageUrl } from '../../lib/og.js';

const themes = await safeFetch(THEMES_LIST);
---

<Base
  title="主題 — 光・門檻・衰敗"
  activeSection="themes"
  room="dark"
  image={ogImageUrl(themes.find((t) => t.cover)?.cover)}
  imageAlt="主題 / Themes"
>
  <div class="container">
    <header class="section-head grid-12">
      <span class="label section-head__label">分類 / Themes</span>
      <h1 class="display section-head__title">主題</h1>
    </header>

    {themes.length > 0 ? (
      <ol class="archive">
        {themes.map((t, i) => (
          <li class="entry grid-12" data-reveal>
            <div class="entry__meta">
              <span class="entry__num">{String(i + 1).padStart(2, '0')}</span>
              <span class="entry__num">{t.count ?? 0} 件</span>
            </div>
            <a class="entry__plate" href={`/themes/${t.slug}`}>
              {t.cover && (
                <img
                  class="entry__img"
                  src={urlFor(t.cover).width(1600).url()}
                  alt={t.title}
                  loading={i < 2 ? 'eager' : 'lazy'}
                />
              )}
              <h2 class="entry__title" style={t.cover ? undefined : 'margin-top:0'}>{t.title}</h2>
              {t.description && (
                <p class="hero__sub" style="color:var(--text-dim);margin-top:0.6rem;max-width:46ch">
                  {t.description}
                </p>
              )}
            </a>
          </li>
        ))}
      </ol>
    ) : (
      <p class="empty">
        還沒有任何主題被標記。<br />
        當作品開始以光、門檻、衰敗彼此呼應，這些線索就會在這裡聚成可循的脈絡。
      </p>
    )}
  </div>
</Base>
