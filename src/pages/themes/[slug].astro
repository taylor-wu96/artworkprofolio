---
import Base from '../../layouts/Base.astro';
import { urlFor, safeFetch } from '../../lib/sanity.js';
import { THEME_SLUGS, THEME_BY_SLUG } from '../../lib/queries.js';

export async function getStaticPaths() {
  const slugs = await safeFetch(THEME_SLUGS);
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const theme = await safeFetch(THEME_BY_SLUG, { slug }, null);

if (!theme) {
  return Astro.redirect('/404');
}

const fmtDate = (d) =>
  d ? new Date(d).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
const total = theme.posts?.length ?? 0;
---

<Base title={`${theme.title} — 主題`} activeSection="themes" room="dark">
  <div class="container">
    <header class="section-head grid-12">
      <span class="label section-head__label">主題 / Theme</span>
      <h1 class="display section-head__title">{theme.title}</h1>
    </header>

    {theme.description && (
      <p class="empty" style="color:var(--text-muted)">{theme.description}</p>
    )}

    {total > 0 ? (
      <ol class="archive">
        {theme.posts.map((p, i) => (
          <li class="entry grid-12" data-reveal>
            <div class="entry__meta">
              <span class="entry__num">作品 {String(total - i).padStart(2, '0')}</span>
              <span class="entry__num">{fmtDate(p.publishedAt)}</span>
            </div>
            <a class="entry__plate" href={`/post/${p.slug}`}>
              {p.cover ? (
                <img
                  class="entry__img"
                  src={urlFor(p.cover).width(1600).url()}
                  alt={p.title}
                  loading={i < 2 ? 'eager' : 'lazy'}
                />
              ) : (
                <div class="entry__placeholder">無影像 / NO IMAGE</div>
              )}
              <h2 class="entry__title">{p.title}</h2>
            </a>
          </li>
        ))}
      </ol>
    ) : (
      <p class="empty">此主題尚無作品。</p>
    )}
  </div>
</Base>
