---
// 三道門指路（G1）：站在「作品／影像／系列」任一個房間時，看得見另外兩個門，
// 並知道自己在哪。把三個概念相近的影像入口，從「三份平行空目錄」變成
// 「同一座館的三個展廳，彼此看得見」。空房（無內容）的門不出現（G3 誠實 IA）。
import { safeFetch } from '../lib/sanity.js';
import { NAV_COUNTS } from '../lib/queries.js';

const { current } = Astro.props; // 'works' | 'gallery' | 'series'

// 取不到計數時不藏門（保守：寧可多顯示，不要誤藏既有房間）。
const counts = await safeFetch(NAV_COUNTS, {}, { galleries: 1, essays: 1, series: 1 });

const DOORS = [
  { key: 'works', href: '/', label: '作品', show: true },
  { key: 'gallery', href: '/gallery', label: '影像', show: (counts?.galleries ?? 0) > 0 },
  { key: 'series', href: '/series', label: '系列', show: (counts?.series ?? 0) > 0 },
].filter((d) => d.show || d.key === current);
---

{DOORS.length > 1 && (
  <nav class="section-cross" aria-label="影像入口">
    {DOORS.map((d) =>
      d.key === current ? (
        <span class="section-cross__here" aria-current="page">{d.label}</span>
      ) : (
        <a href={d.href}>{d.label}</a>
      )
    )}
  </nav>
)}
