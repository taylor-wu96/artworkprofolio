---
// 放映模式（Projection）：把單張放大升級成「滿版暗場・序列翻閱・顯影」的觀看儀器。
// 參考 Crewdson（滿版敬畏）／Porodina（翻頁序列）／Davison（編號），縫進本站既有
// 的暗房・準星・簽名語言。任何 img.zoomable 點擊即進入；←/→ 翻過整頁的影像序列。
// 無相依、document 層級委派，撐過 View Transitions 導覽。
---

<div id="projection" class="pjx" aria-hidden="true" role="dialog" aria-modal="true" aria-label="影像放映">
  <button class="pjx__close" type="button" aria-label="關閉放映">關閉 ×</button>

  <!-- 序列（凝視）／ 總覽（印樣選片）：同一捲底片的兩種看法。單張時隱藏（data-single）。 -->
  <div class="pjx__views" role="group" aria-label="檢視模式">
    <button class="pjx__view pjx__view--slides" type="button" aria-pressed="true">序列</button>
    <span class="pjx__viewsep" aria-hidden="true">／</span>
    <button class="pjx__view pjx__view--grid" type="button" aria-pressed="false">總覽</button>
  </div>

  <button class="pjx__nav pjx__prev" type="button" aria-label="上一張">←</button>
  <button class="pjx__nav pjx__next" type="button" aria-label="下一張">→</button>

  <!-- 印樣台：整捲縮圖密排，點任一格顯影跳入序列。縮圖複用已載入資源，不重打高解析。 -->
  <div class="pjx__grid" role="group" aria-label="影像總覽"></div>

  <div class="pjx__stage">
    <figure class="pjx__frame">
      <img class="pjx__img" alt="" />
      <!-- 機器擷取：每格落定時四角括弧框選（自成一格，不耦合全站準星）。 -->
      <b class="pjx__c tl" aria-hidden="true"></b><b class="pjx__c tr" aria-hidden="true"></b>
      <b class="pjx__c bl" aria-hidden="true"></b><b class="pjx__c br" aria-hidden="true"></b>
    </figure>
  </div>

  <div class="pjx__chrome">
    <span class="pjx__count" aria-live="polite"></span>
    <span class="pjx__sig data-strip"></span>
    <!-- 機器讀檔：這一格的真實 EXIF（光圈·快門·ISO·焦段·鏡頭）。無則留空、不顯。 -->
    <span class="pjx__exif" aria-live="polite"></span>
    <span class="pjx__caption"></span>
  </div>
</div>

<script>
  function el<T extends Element = HTMLElement>(sel: string) {
    return document.querySelector(sel) as T | null;
  }

  if (!(window as any).__projectionBound) {
    (window as any).__projectionBound = true;

    const box = () => el('#projection') as HTMLElement | null;
    const img = () => el('.pjx__img') as HTMLImageElement | null;

    let items: HTMLImageElement[] = []; // 當前序列（整頁的 img.zoomable）
    let current = -1;
    let view: 'slides' | 'grid' = 'slides'; // 序列（凝視）／ 總覽（印樣選片）
    let zoomed = false;
    let lastFocus: HTMLElement | null = null; // 開啟前的焦點，關閉時還原（無障礙）

    // 觸控手勢狀態（§15 觸控契約：tap/swipe/drag 消歧）。
    const coarse = () => window.matchMedia('(pointer: coarse)').matches;
    const stage = () => el('.pjx__stage') as HTMLElement | null;
    let tStartX = 0, tStartY = 0, tStartT = 0;
    let dragging = false; // 向下拖曳關閉中
    let lastTap = 0; // 上次 tap 時戳（雙擊偵測）
    let tapTimer: ReturnType<typeof setTimeout> | null = null;

    // 拖曳殘留復位（舞台位移、暗場透明度）。
    function resetDrag() {
      const st = stage(), b = box();
      if (st) { st.style.transition = ''; st.style.transform = ''; }
      if (b) b.style.opacity = '';
    }

    // 對話框內可聚焦元素（可見的控制鈕）——focus trap 用。
    function focusables(): HTMLElement[] {
      const b = box();
      if (!b) return [];
      return Array.from(b.querySelectorAll<HTMLElement>('button')).filter(
        (n) => n.offsetParent !== null
      );
    }

    const fmt = (n: number) => String(n).padStart(2, '0');

    function captionOf(node: HTMLImageElement) {
      const cap = node.closest('figure')?.querySelector('figcaption')?.textContent?.trim();
      return cap || node.getAttribute('alt') || '';
    }

    function setZoom(on: boolean) {
      const b = box();
      if (!b) return;
      zoomed = on;
      b.classList.toggle('is-zoomed', on);
      if (!on) {
        const im = img();
        if (im) im.style.transform = '';
      }
    }

    // 顯影：先放已快取的縮圖（模糊遮蔽切換），背景載入高解析後轉銳利。
    function develop(node: HTMLImageElement) {
      const im = img();
      if (!im) return;
      const thumb = node.currentSrc || node.src;
      const full = node.dataset.full || thumb;
      im.classList.add('is-developing');
      im.src = thumb;
      im.alt = node.getAttribute('alt') || '';
      if (full && full !== thumb) {
        const pre = new Image();
        pre.onload = () => {
          im.src = full;
          requestAnimationFrame(() => im.classList.remove('is-developing'));
        };
        pre.onerror = () => im.classList.remove('is-developing');
        pre.src = full;
      } else {
        requestAnimationFrame(() => im.classList.remove('is-developing'));
      }
    }

    function render() {
      const b = box();
      const node = items[current];
      if (!b || !node) return;
      setZoom(false);
      develop(node);

      // 機器擷取這一格：四角括弧重新框選（重啟動畫）。
      const frame = el('.pjx__frame') as HTMLElement | null;
      if (frame) {
        frame.classList.remove('is-acquiring');
        void frame.offsetWidth; // 強制 reflow 以重啟動畫
        frame.classList.add('is-acquiring');
      }

      const count = el('.pjx__count');
      if (count) count.textContent = items.length > 1 ? `${fmt(current + 1)} / ${fmt(items.length)}` : '';

      const cap = el('.pjx__caption');
      if (cap) cap.textContent = captionOf(node);

      // 機器讀檔：這一格影像的真實 EXIF（Plate 已算好放在 data-exif）。無則留空。
      const ex = el('.pjx__exif');
      if (ex) ex.textContent = node.dataset.exif || '';

      // 簽名標籤：複製當頁的機器簽名資料條（保留綠色 code）。閱讀頁無則留空。
      const sig = el('.pjx__sig') as HTMLElement | null;
      const pageSig = el('.work__data, .data-strip:not(.pjx__sig)') as HTMLElement | null;
      if (sig) sig.innerHTML = pageSig ? pageSig.innerHTML : '';

      // 機器擷取了這一格：派發鎖定事件（音景模組響快門 blip）。
      // 亮房（閱讀）放映不發聲、不框選——閱讀不被監視（DESIGN §13/§15 point 4）。
      if (!b.classList.contains('pjx--light')) {
        document.dispatchEvent(new CustomEvent('reticle:lock'));
      }
    }

    function go(delta: number) {
      if (items.length < 2) return;
      current = (current + delta + items.length) % items.length; // 循環
      render();
    }

    // ── 總覽（Grid）：整捲印樣 ────────────────────────────────────────────
    // 縮圖複用各序列影像「已載入」的來源（currentSrc），絕不重打高解析——
    // 開一次總覽不該變成 18 個網路請求（DESIGN 省流量）。
    function buildGrid() {
      const grid = el('.pjx__grid');
      if (!grid) return;
      grid.innerHTML = '';
      items.forEach((node, i) => {
        const cell = document.createElement('button');
        cell.type = 'button';
        cell.className = 'pjx__cell' + (i === current ? ' is-current' : '');
        cell.dataset.index = String(i);
        cell.setAttribute('aria-label', `第 ${i + 1} 張，共 ${items.length} 張`);
        if (i === current) cell.setAttribute('aria-current', 'true');
        const im = document.createElement('img');
        im.src = node.currentSrc || node.src;
        im.alt = node.getAttribute('alt') || '';
        im.loading = 'lazy';
        im.decoding = 'async';
        const num = document.createElement('span');
        num.className = 'pjx__cellnum';
        num.textContent = fmt(i + 1);
        cell.append(im, num);
        grid.appendChild(cell);
      });
    }

    // 切換視圖：總覽即時建格＋移焦當前格；回序列＝重新「擷取」當前影像（綠括弧）。
    function setView(v: 'slides' | 'grid') {
      const b = box();
      if (!b || items.length < 2) return; // 單張無總覽
      view = v;
      if (v === 'grid') {
        setZoom(false);
        buildGrid();
      }
      b.classList.toggle('is-grid', v === 'grid');
      (el('.pjx__view--slides') as HTMLElement | null)?.setAttribute('aria-pressed', String(v === 'slides'));
      (el('.pjx__view--grid') as HTMLElement | null)?.setAttribute('aria-pressed', String(v === 'grid'));
      if (v === 'grid') {
        // 移焦「你剛剛在這一格」，並捲入視野（鍵盤使用者立即可操作）。
        requestAnimationFrame(() => {
          const cur = (b.querySelector('.pjx__cell.is-current') ||
            b.querySelector('.pjx__cell')) as HTMLElement | null;
          cur?.focus();
          cur?.scrollIntoView({ block: 'nearest' });
        });
      } else {
        render(); // 回序列：重新顯影＋四角括弧擷取當前格
        requestAnimationFrame(() => (el('.pjx__close') as HTMLElement | null)?.focus());
      }
    }

    // 總覽下方向鍵：在印樣格間移動焦點（Enter/Space 由原生按鈕觸發跳入）。
    function focusCell(delta: number) {
      const b = box();
      if (!b) return;
      const cells = Array.from(b.querySelectorAll<HTMLElement>('.pjx__cell'));
      if (!cells.length) return;
      let idx = cells.indexOf(document.activeElement as HTMLElement);
      if (idx < 0) idx = cells.findIndex((c) => c.classList.contains('is-current'));
      if (idx < 0) idx = 0;
      const next = cells[(idx + delta + cells.length) % cells.length];
      next.focus();
      next.scrollIntoView({ block: 'nearest' });
    }

    function open(node: HTMLImageElement) {
      const b = box();
      if (!b) return;
      // 記住開啟前的焦點，關閉時還原（無障礙：不讓焦點掉到頁首）。
      lastFocus = (document.activeElement as HTMLElement) ?? node;
      resetDrag();
      b.classList.remove('is-bare');
      // 房間一致：亮房（閱讀）影像進「安靜亮場」放映，不喚暗房監視儀器
      // （無綠括弧／無機器簽名／無快門）。暗房影像走完整放映。見 DESIGN §15 point 4。
      b.classList.toggle('pjx--light', document.documentElement.getAttribute('data-room') !== 'dark');
      // 序列＝整頁的 zoomable 影像（DOM 順序）；找出點擊者的索引。
      items = Array.from(document.querySelectorAll<HTMLImageElement>('img.zoomable'));
      current = Math.max(0, items.indexOf(node));
      b.toggleAttribute('data-single', items.length < 2);
      // 每次開啟都從「序列」起手（凝視優先）。
      view = 'slides';
      b.classList.remove('is-grid');
      (el('.pjx__view--slides') as HTMLElement | null)?.setAttribute('aria-pressed', 'true');
      (el('.pjx__view--grid') as HTMLElement | null)?.setAttribute('aria-pressed', 'false');
      render();
      b.setAttribute('aria-hidden', 'false');
      document.documentElement.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        b.setAttribute('data-open', '');
        // 移焦進對話框（關閉鈕），讓鍵盤使用者立即可操作、且被 trap 困在內。
        (el('.pjx__close') as HTMLElement | null)?.focus();
      });
    }

    function close() {
      const b = box();
      if (!b) return;
      setZoom(false);
      b.removeAttribute('data-open');
      b.setAttribute('aria-hidden', 'true');
      document.documentElement.style.overflow = '';
      // 還原焦點到開啟前的元素；若無有效目標（如點圖開啟、img 不可聚焦），
      // 則 blur 目前焦點，讓它離開已隱藏的對話框（不滯留在 aria-hidden 內）。
      if (lastFocus && lastFocus !== document.body && document.contains(lastFocus)) {
        lastFocus.focus();
      } else {
        (document.activeElement as HTMLElement | null)?.blur();
      }
      lastFocus = null;
      const im = img();
      setTimeout(() => {
        if (!b.hasAttribute('data-open') && im) im.src = '';
      }, 600);
    }

    // 用 aria-hidden 判定開啟（同步設定）；data-open 僅供 CSS 淡入過渡（rAF 後才上，
    // 可能被背景分頁節流）。鍵盤/縮放因此不受繪製時機影響、開啟即可用。
    const isOpen = () => box()?.getAttribute('aria-hidden') === 'false';

    // 開啟：點任何 zoomable 影像
    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      const zoomable = t.closest('img.zoomable') as HTMLImageElement | null;
      if (zoomable && !isOpen()) {
        e.preventDefault();
        open(zoomable);
        return;
      }
      if (!isOpen()) return;

      // 控制鈕：close ＋ 左右邊緣熱區（fine）。coarse 翻頁交給水平 swipe（§15）。
      if (t.closest('.pjx__close')) return close();
      if (t.closest('.pjx__prev')) return go(-1);
      if (t.closest('.pjx__next')) return go(1);

      // 視圖切換與印樣選格：fine／coarse 皆走 click（按鈕原生），故置於 coarse 早退之前。
      const viewBtn = t.closest('.pjx__view') as HTMLElement | null;
      if (viewBtn) return setView(viewBtn.classList.contains('pjx__view--grid') ? 'grid' : 'slides');
      const cell = t.closest('.pjx__cell') as HTMLElement | null;
      if (cell) {
        current = Number(cell.dataset.index) || 0;
        return setView('slides'); // 顯影跳入該格
      }

      // 觸控（coarse）：zoom／關閉一律不靠 click——交給 touchend 的 tap 消歧與
      // 向下拖曳關閉（§15）。避免「點暗場即關」「點影像即縮放」在拇指下誤觸。
      if (coarse()) return;

      // 滑鼠（fine）：點影像＝切換放大；點暗場（非影像/非控制）＝關閉。
      if (t.closest('.pjx__img')) {
        e.stopPropagation();
        setZoom(!zoomed);
        return;
      }
      if (t.closest('.pjx')) close();
    });

    // 放大時：指標移動平移影像（看細節）。滑鼠與觸控皆適用。
    document.addEventListener('pointermove', (e) => {
      if (!isOpen() || !zoomed) return;
      const im = img();
      if (!im) return;
      const rx = e.clientX / window.innerWidth - 0.5;
      const ry = e.clientY / window.innerHeight - 0.5;
      im.style.transform = `scale(2) translate(${-rx * 42}%, ${-ry * 42}%)`;
    });

    // 鍵盤：Esc 關、←/→ 翻頁、Tab 鎖在對話框內（focus trap）。
    document.addEventListener('keydown', (e) => {
      if (!isOpen()) return;
      // 總覽：Esc 退回序列（單層），方向鍵移動印樣格焦點。
      if (view === 'grid') {
        if (e.key === 'Escape') return setView('slides');
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); return focusCell(1); }
        if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { e.preventDefault(); return focusCell(-1); }
        // Tab 仍交給下方 focus trap
      } else {
        if (e.key === 'Escape') return close();
        if (e.key === 'ArrowLeft') return go(-1);
        if (e.key === 'ArrowRight') return go(1);
      }
      if (e.key === 'Tab') {
        const f = focusables();
        if (f.length === 0) {
          e.preventDefault();
          return;
        }
        const b = box();
        const first = f[0];
        const last = f[f.length - 1];
        const active = document.activeElement as HTMLElement | null;
        const inside = !!(b && active && b.contains(active));
        if (e.shiftKey) {
          if (!inside || active === first) {
            e.preventDefault();
            last.focus();
          }
        } else {
          if (!inside || active === last) {
            e.preventDefault();
            first.focus();
          }
        }
      }
    });

    // ── 觸控手勢（§15）：tap 切換 chrome、double-tap 縮放、水平滑翻頁、
    //    向下拖曳關閉。位移＋時間消歧，避免誤觸關閉。──────────────────────
    document.addEventListener('touchstart', (e) => {
      if (!isOpen() || view === 'grid') return; // 總覽交給原生捲動
      const tc = e.changedTouches[0];
      tStartX = tc.clientX; tStartY = tc.clientY; tStartT = Date.now();
      dragging = false;
    }, { passive: true });

    document.addEventListener('touchmove', (e) => {
      if (!isOpen() || zoomed || view === 'grid') return; // 放大／總覽交給原生
      const tc = e.changedTouches[0];
      const dx = tc.clientX - tStartX;
      const dy = tc.clientY - tStartY;
      // 垂直為主且向下 → 進入「拖曳關閉」預覽（跟手位移＋暗場漸淡）。
      if (!dragging && dy > 8 && Math.abs(dy) > Math.abs(dx)) dragging = true;
      if (dragging) {
        const st = stage(), b = box();
        const d = Math.max(0, dy);
        if (st) { st.style.transition = 'none'; st.style.transform = `translateY(${d}px)`; }
        if (b) b.style.opacity = String(Math.max(0.2, 1 - d / 600));
      }
    }, { passive: true });

    document.addEventListener('touchend', (e) => {
      if (!isOpen() || view === 'grid') return; // 總覽：tap 跳格由 click 處理
      const tc = e.changedTouches[0];
      const dx = tc.clientX - tStartX;
      const dy = tc.clientY - tStartY;
      const dt = Date.now() - tStartT;

      // 拖曳關閉：過閾值（90px）關閉，否則彈回。
      if (dragging) {
        dragging = false;
        const st = stage(), b = box();
        if (dy > 90) {
          if (b) b.style.opacity = '';
          resetDrag();
          return close();
        }
        if (b) b.style.opacity = '';
        if (st) {
          st.style.transition = 'transform var(--dur) var(--ease)';
          st.style.transform = '';
          setTimeout(() => { const s = stage(); if (s) s.style.transition = ''; }, 360);
        }
        return;
      }

      // tap：位移小、時間短。
      if (Math.abs(dx) < 10 && Math.abs(dy) < 10 && dt < 250) {
        if ((e.target as HTMLElement).closest('button')) return; // 控制鈕交給 click
        const now = Date.now();
        if (now - lastTap < 300) { // double-tap → 縮放切換
          if (tapTimer) { clearTimeout(tapTimer); tapTimer = null; }
          lastTap = 0;
          setZoom(!zoomed);
          return;
        }
        lastTap = now;
        // 單 tap → 延後確認後切換底部 chrome（看純淨影像 ↔ 看資料）；不關閉、不縮放。
        if (tapTimer) clearTimeout(tapTimer);
        tapTimer = setTimeout(() => {
          tapTimer = null;
          if (!zoomed) box()?.classList.toggle('is-bare');
        }, 280);
        return;
      }

      // 水平滑動翻頁（未拖曳關閉、未縮放、橫向為主）。
      if (!zoomed && Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
        go(dx < 0 ? 1 : -1);
      }
    }, { passive: true });

    // View Transitions 導覽後收起
    document.addEventListener('astro:after-swap', () => {
      const b = box();
      if (b) {
        b.removeAttribute('data-open');
        b.setAttribute('aria-hidden', 'true');
        b.classList.remove('is-grid');
      }
      view = 'slides';
      document.documentElement.style.overflow = '';
      lastFocus = null; // 導覽後焦點來源已失效，勿還原
    });
  }
</script>
