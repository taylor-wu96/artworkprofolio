---
// 無相依的影像 lightbox。任何帶 class="zoomable" 的 <img> 點擊即放大。
// 用 document 層級事件委派，能在 View Transitions 導覽後持續作用。
// 關閉時用 visibility/pointer-events 收起，避免覆蓋層攔截全站點擊。
---

<div id="lightbox" class="lightbox" aria-hidden="true">
  <button class="lightbox__close" type="button" aria-label="關閉">關閉 ×</button>
  <img class="lightbox__img" alt="" />
</div>

<script>
  function box() {
    return document.getElementById('lightbox');
  }

  function openBox(src: string, alt: string) {
    const el = box();
    const img = el?.querySelector('.lightbox__img') as HTMLImageElement | null;
    if (!el || !img) return;
    img.src = src;
    img.alt = alt;
    el.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(() => el.setAttribute('data-open', ''));
  }

  function closeBox() {
    const el = box();
    const img = el?.querySelector('.lightbox__img') as HTMLImageElement | null;
    if (!el || !img) return;
    el.removeAttribute('data-open');
    el.setAttribute('aria-hidden', 'true');
    setTimeout(() => {
      if (!el.hasAttribute('data-open')) img.src = '';
    }, 800);
  }

  if (!(window as any).__lightboxBound) {
    (window as any).__lightboxBound = true;

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const zoomable = target.closest('img.zoomable') as HTMLImageElement | null;
      if (zoomable) {
        e.preventDefault();
        openBox(zoomable.dataset.full || zoomable.currentSrc || zoomable.src, zoomable.alt);
        return;
      }
      if (target.closest('#lightbox')) closeBox();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && box()?.hasAttribute('data-open')) closeBox();
    });

    document.addEventListener('astro:after-swap', () => box()?.removeAttribute('data-open'));
  }
</script>
