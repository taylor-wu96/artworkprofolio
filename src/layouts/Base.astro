---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Lightbox from '../components/Lightbox.astro';
import Newsletter from '../components/Newsletter.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  activeSection?: 'works' | 'gallery' | 'writings' | 'themes' | 'about';
}

const {
  title = '光・門檻・衰敗 — 攝影檔案',
  description = '一個關於光、門檻與邊界、衰敗與生機並存的攝影檔案。',
  image,
  activeSection,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;
const path = Astro.url.pathname;
const isWorks = activeSection ? activeSection === 'works' : (path === '/' || path.startsWith('/post'));
const isGallery = activeSection ? activeSection === 'gallery' : path.startsWith('/gallery');
const isWritings = activeSection ? activeSection === 'writings' : path.startsWith('/writings');
const isThemes = activeSection ? activeSection === 'themes' : path.startsWith('/themes');
const isAbout = activeSection ? activeSection === 'about' : path.startsWith('/about');
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
    <ClientRouter />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="brand" href="/">光・門檻・衰敗</a>
        <nav class="nav" aria-label="主導覽">
          <a href="/" aria-current={isWorks ? 'page' : undefined}>作品</a>
          <a href="/gallery" aria-current={isGallery ? 'page' : undefined}>影像</a>
          <a href="/writings" aria-current={isWritings ? 'page' : undefined}>散文</a>
          <a href="/themes" aria-current={isThemes ? 'page' : undefined}>主題</a>
          <a href="/about" aria-current={isAbout ? 'page' : undefined}>關於</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <Newsletter />

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <span>光・門檻・衰敗</span>
        <span>攝影檔案 · {new Date().getFullYear()}</span>
        <a href="/rss.xml">RSS</a>
      </div>
    </footer>

    <Lightbox />

    <script>
      // 緩慢、克制的入場揭示：元素進入視窗才現形。
      function observe() {
        const els = document.querySelectorAll('[data-reveal]:not(.is-visible)');
        if (!('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
        );
        els.forEach((el) => io.observe(el));
      }
      observe();
      document.addEventListener('astro:after-swap', observe);
    </script>
  </body>
</html>
