---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Lightbox from '../components/Lightbox.astro';
import Newsletter from '../components/Newsletter.astro';
import { safeFetch } from '../lib/sanity.js';
import { NAV_COUNTS } from '../lib/queries.js';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  activeSection?: 'works' | 'gallery' | 'series' | 'writings' | 'themes' | 'about';
  // 兩個房間：暗房（圖錄・作品・3D）／亮房（閱讀，預設）。見 DESIGN §1。
  room?: 'light' | 'dark';
}

const {
  title = '潮濕的質地 — 攝影檔案',
  description = '一個關於光、門檻與邊界、衰敗與生機並存的攝影檔案。',
  image,
  imageAlt,
  activeSection,
  room = 'light',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;
const SITE_NAME = '潮濕的質地';
const path = Astro.url.pathname;
const isWorks = activeSection ? activeSection === 'works' : (path === '/' || path.startsWith('/post'));
const isGallery = activeSection ? activeSection === 'gallery' : path.startsWith('/gallery');
const isSeries = activeSection ? activeSection === 'series' : path.startsWith('/series');
const isWritings = activeSection ? activeSection === 'writings' : path.startsWith('/writings');
const isThemes = activeSection ? activeSection === 'themes' : path.startsWith('/themes');
const isAbout = activeSection ? activeSection === 'about' : path.startsWith('/about');

// G3 誠實 IA：空房不在大廳擺門。取不到計數時不藏（保守，寧顯勿誤藏）；
// 當前所在的房間一律顯示（即使空），避免 aria-current 指向不存在的門。
const navCounts = await safeFetch(NAV_COUNTS, {}, { galleries: 1, essays: 1, series: 1 });
const showGallery = (navCounts?.galleries ?? 0) > 0 || isGallery;
const showSeries = (navCounts?.series ?? 0) > 0 || isSeries;
const showWritings = (navCounts?.essays ?? 0) > 0 || isWritings;
---

<!doctype html>
<html lang="zh-Hant" data-room={room}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- G2 連續的身體：瀏覽器 chrome 色跟著房間走（暗房暗室／亮房紙白），延伸到視窗外框。 -->
    <meta name="theme-color" content={room === 'dark' ? '#0c0c0b' : '#f4f4f2'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- 三體：標題黑體 Noto Sans TC（grotesque，展示用輕量→中量）＋ 長文宋體 Noto Serif TC
         （CJK 由 unicode-range 自動 subset；display=swap 避免 FOIT）。 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&family=Noto+Serif+TC:wght@400;600&display=swap"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="zh_Hant_TW" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && (
      <>
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={imageAlt ?? title} />
      </>
    )}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
    <ClientRouter />
  </head>
  <body>
    <!-- 光揭示轉場層（Turrell）：房間切換時以目標房間表面色覆蓋再淡出。 -->
    <div id="room-veil" aria-hidden="true"></div>

    <!-- 閱讀進度條：僅在標記 [data-read-progress] 的長文頁顯示綠填充。 -->
    <div class="read-progress" aria-hidden="true"><span></span></div>

    <header class="site-header">
      <div class="container site-header__inner">
        <a class="brand" href="/">潮濕的質地</a>
        <div class="site-header__right">
        <nav class="nav" aria-label="主導覽">
          <a href="/" aria-current={isWorks ? 'page' : undefined}>作品</a>
          {showGallery && <a href="/gallery" aria-current={isGallery ? 'page' : undefined}>影像</a>}
          {showSeries && <a href="/series" aria-current={isSeries ? 'page' : undefined}>系列</a>}
          {showWritings && <a href="/writings" aria-current={isWritings ? 'page' : undefined}>散文</a>}
          <a href="/about" aria-current={isAbout ? 'page' : undefined}>關於</a>
        </nav>
        {room === 'dark' && (
          <button
            class="sound-toggle"
            type="button"
            aria-pressed="false"
            aria-label="切換環境聲音"
            title="環境聲音"
          >
            <span class="sound-toggle__waves" aria-hidden="true">
              <i></i><i></i><i></i>
            </span>
            <span class="sound-toggle__label">聲</span>
          </button>
        )}
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <Newsletter />

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <span>潮濕的質地</span>
        <span>攝影檔案 · {new Date().getFullYear()}</span>
        <a href="/rss.xml">RSS</a>
      </div>
    </footer>

    <Lightbox />

    <!-- 全站行為腳本（階段 I2：6 段原 inline script 已抽成 src/scripts/* 模組）。 -->
    <script>
      import '../scripts';
    </script>
  </body>
</html>
