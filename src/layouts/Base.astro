---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Lightbox from '../components/Lightbox.astro';
import Newsletter from '../components/Newsletter.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  activeSection?: 'works' | 'gallery' | 'writings' | 'themes' | 'about';
  // 兩個房間：暗房（圖錄・作品・3D）／亮房（閱讀，預設）。見 DESIGN §1。
  room?: 'light' | 'dark';
}

const {
  title = '光・門檻・衰敗 — 攝影檔案',
  description = '一個關於光、門檻與邊界、衰敗與生機並存的攝影檔案。',
  image,
  activeSection,
  room = 'light',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;
const path = Astro.url.pathname;
const isWorks = activeSection ? activeSection === 'works' : (path === '/' || path.startsWith('/post'));
const isGallery = activeSection ? activeSection === 'gallery' : path.startsWith('/gallery');
const isWritings = activeSection ? activeSection === 'writings' : path.startsWith('/writings');
const isThemes = activeSection ? activeSection === 'themes' : path.startsWith('/themes');
const isAbout = activeSection ? activeSection === 'about' : path.startsWith('/about');
---

<!doctype html>
<html lang="zh-Hant" data-room={room}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- 編輯雙體：長文宋體 Noto Serif TC（CJK 由 unicode-range 自動 subset） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600&display=swap"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
    <ClientRouter />
  </head>
  <body>
    <!-- 閱讀進度條：僅在標記 [data-read-progress] 的長文頁顯示綠填充。 -->
    <div class="read-progress" aria-hidden="true"><span></span></div>

    <header class="site-header">
      <div class="container site-header__inner">
        <a class="brand" href="/">光・門檻・衰敗</a>
        <nav class="nav" aria-label="主導覽">
          <a href="/" aria-current={isWorks ? 'page' : undefined}>作品</a>
          <a href="/gallery" aria-current={isGallery ? 'page' : undefined}>影像</a>
          <a href="/writings" aria-current={isWritings ? 'page' : undefined}>散文</a>
          <a href="/themes" aria-current={isThemes ? 'page' : undefined}>主題</a>
          <a href="/about" aria-current={isAbout ? 'page' : undefined}>關於</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <Newsletter />

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <span>光・門檻・衰敗</span>
        <span>攝影檔案 · {new Date().getFullYear()}</span>
        <a href="/rss.xml">RSS</a>
      </div>
    </footer>

    <Lightbox />

    <script>
      // 緩慢、克制的入場揭示：元素進入視窗才現形。
      function observe() {
        const els = document.querySelectorAll('[data-reveal]:not(.is-visible)');
        if (!('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
        );
        els.forEach((el) => io.observe(el));
      }
      observe();
      document.addEventListener('astro:after-swap', observe);
    </script>

    <script>
      // 閱讀進度：追蹤 [data-read-progress] 文章捲動，綠色填充（亮房長文）。
      function bindReadProgress() {
        const fill = document.querySelector<HTMLElement>('.read-progress > span');
        const article = document.querySelector<HTMLElement>('[data-read-progress]');
        if (!fill) return;
        if (!article) {
          fill.style.width = '0';
          return;
        }
        let raf = 0;
        const update = () => {
          raf = 0;
          const start = article.offsetTop;
          const span = article.offsetHeight - window.innerHeight;
          const p = span > 0 ? (window.scrollY - start) / span : 0;
          fill.style.width = `${Math.min(Math.max(p, 0), 1) * 100}%`;
        };
        const onScroll = () => {
          if (!raf) raf = requestAnimationFrame(update);
        };
        update();
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
      }
      bindReadProgress();
      document.addEventListener('astro:page-load', bindReadProgress);
    </script>

    <script>
      // 機器視覺準星（觀看的機器 v3）：暗房專屬，跟隨游標、hover 作品時框選鎖定。
      // 凝視/監視母題（Steyerl・Lozano-Hemmer・Paglen）＋ net-art 反應手勢。
      (function () {
        const fine = window.matchMedia('(pointer: fine)').matches;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!fine || reduce) return; // 觸控/減少動態：不啟用

        const SEL = '.entry__plate, .work__cover, .gallery-item__media, .plates figure';
        const target = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
        const pos = { x: target.x, y: target.y };
        let el: HTMLElement | null = null;
        let lockEl: Element | null = null;
        let active = false;
        let raf = 0;

        const isDark = () =>
          document.documentElement.getAttribute('data-room') === 'dark';

        function ensureEl() {
          if (el && document.body.contains(el)) return;
          el = document.createElement('div');
          el.className = 'reticle';
          el.setAttribute('aria-hidden', 'true');
          el.innerHTML =
            '<i class="reticle__x"></i><i class="reticle__y"></i>' +
            '<b class="reticle__c tl"></b><b class="reticle__c tr"></b>' +
            '<b class="reticle__c bl"></b><b class="reticle__c br"></b>';
          document.body.appendChild(el);
        }

        function frame() {
          raf = requestAnimationFrame(frame);
          if (!el) return;
          if (lockEl && document.contains(lockEl)) {
            const r = (lockEl as HTMLElement).getBoundingClientRect();
            const pad = 8;
            el.style.width = r.width + pad * 2 + 'px';
            el.style.height = r.height + pad * 2 + 'px';
            el.style.transform =
              'translate3d(' + (r.left - pad) + 'px,' + (r.top - pad) + 'px,0)';
          } else {
            pos.x += (target.x - pos.x) * 0.25;
            pos.y += (target.y - pos.y) * 0.25;
            if (el.style.width !== '26px') {
              el.style.width = '26px';
              el.style.height = '26px';
            }
            el.style.transform =
              'translate3d(' + (pos.x - 13) + 'px,' + (pos.y - 13) + 'px,0)';
          }
        }

        document.addEventListener(
          'pointermove',
          (e) => {
            target.x = e.clientX;
            target.y = e.clientY;
            if (!active && el && isDark()) {
              active = true;
              el.setAttribute('data-active', '');
            }
          },
          { passive: true }
        );
        document.addEventListener(
          'pointerover',
          (e) => {
            if (!el || !isDark()) return;
            const t = (e.target as Element)?.closest?.(SEL);
            if (t) {
              lockEl = t;
              el.setAttribute('data-lock', '');
            }
          },
          { passive: true }
        );
        document.addEventListener(
          'pointerout',
          (e) => {
            if (!el) return;
            const t = (e.target as Element)?.closest?.(SEL);
            if (t) {
              lockEl = null;
              el.removeAttribute('data-lock');
            }
          },
          { passive: true }
        );
        window.addEventListener('blur', () => {
          active = false;
          lockEl = null;
          if (el) {
            el.removeAttribute('data-active');
            el.removeAttribute('data-lock');
          }
        });

        function sync() {
          if (isDark()) {
            ensureEl();
            if (!raf) raf = requestAnimationFrame(frame);
          } else if (el) {
            el.remove();
            el = null;
            lockEl = null;
            active = false;
          }
        }
        sync();
        document.addEventListener('astro:page-load', sync);
      })();
    </script>
  </body>
</html>
