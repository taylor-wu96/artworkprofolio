---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Lightbox from '../components/Lightbox.astro';
import Newsletter from '../components/Newsletter.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  activeSection?: 'works' | 'gallery' | 'series' | 'writings' | 'themes' | 'about';
  // 兩個房間：暗房（圖錄・作品・3D）／亮房（閱讀，預設）。見 DESIGN §1。
  room?: 'light' | 'dark';
}

const {
  title = '光・門檻・衰敗 — 攝影檔案',
  description = '一個關於光、門檻與邊界、衰敗與生機並存的攝影檔案。',
  image,
  activeSection,
  room = 'light',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;
const path = Astro.url.pathname;
const isWorks = activeSection ? activeSection === 'works' : (path === '/' || path.startsWith('/post'));
const isGallery = activeSection ? activeSection === 'gallery' : path.startsWith('/gallery');
const isSeries = activeSection ? activeSection === 'series' : path.startsWith('/series');
const isWritings = activeSection ? activeSection === 'writings' : path.startsWith('/writings');
const isThemes = activeSection ? activeSection === 'themes' : path.startsWith('/themes');
const isAbout = activeSection ? activeSection === 'about' : path.startsWith('/about');
---

<!doctype html>
<html lang="zh-Hant" data-room={room}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- 編輯雙體：長文宋體 Noto Serif TC（CJK 由 unicode-range 自動 subset） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600&display=swap"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
    <ClientRouter />
  </head>
  <body>
    <!-- 光揭示轉場層（Turrell）：房間切換時以目標房間表面色覆蓋再淡出。 -->
    <div id="room-veil" aria-hidden="true"></div>

    <!-- 閱讀進度條：僅在標記 [data-read-progress] 的長文頁顯示綠填充。 -->
    <div class="read-progress" aria-hidden="true"><span></span></div>

    <header class="site-header">
      <div class="container site-header__inner">
        <a class="brand" href="/">光・門檻・衰敗</a>
        <div class="site-header__right">
        <nav class="nav" aria-label="主導覽">
          <a href="/" aria-current={isWorks ? 'page' : undefined}>作品</a>
          <a href="/gallery" aria-current={isGallery ? 'page' : undefined}>影像</a>
          <a href="/series" aria-current={isSeries ? 'page' : undefined}>系列</a>
          <a href="/writings" aria-current={isWritings ? 'page' : undefined}>散文</a>
          <a href="/themes" aria-current={isThemes ? 'page' : undefined}>主題</a>
          <a href="/about" aria-current={isAbout ? 'page' : undefined}>關於</a>
        </nav>
        {room === 'dark' && (
          <button
            class="sound-toggle"
            type="button"
            aria-pressed="false"
            aria-label="切換環境聲音"
            title="環境聲音"
          >
            <span class="sound-toggle__waves" aria-hidden="true">
              <i></i><i></i><i></i>
            </span>
            <span class="sound-toggle__label">聲</span>
          </button>
        )}
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <Newsletter />

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <span>光・門檻・衰敗</span>
        <span>攝影檔案 · {new Date().getFullYear()}</span>
        <a href="/rss.xml">RSS</a>
      </div>
    </footer>

    <Lightbox />

    <!-- 全站行為腳本（階段 I2：6 段原 inline script 已抽成 src/scripts/* 模組）。 -->
    <script>
      import '../scripts';
    </script>
  </body>
</html>
